{% doc %}
  @prompt
    Build a Mini Video Cards Slider component:
    
    Show 3.5 columns (half of 4th visible).
    
    Hide arrows when all videos fit.
    
    Each card = full clickable thumbnail, title appears below.
    
    Support up to 8 videos with on/off toggle and placeholder if missing URL.
    
    Size controls: arrows, play button, title (min 5 px).
    
    Gap + padding controllers for both element and cards (vertical & horizontal).
    
    Remove headline space if deleted to make layout compact.
    
    Alignment: left, center, right, or evenly spaced.
    
    Borders available for all card types, not only circular.
    
    Video shapes:
    
    Circle (story, colored border),
    
    Portrait (reels),
    
    Landscape (YouTube),
    
    Square (Facebook).
    Toggle play icon visibility.
    
    Hover: glowing blurred background instead of lift; choose color & blur size. Glow appears outside, not inside; remove top/bottom ceiling so glow fades naturally while keeping left/right limits.
    
    Popup: opens YouTube or other video, no auto-close, popup adapts to video ratio; include dropdown (16:9 / 9:16 / 1:1).
    
    Navigation: arrows under slider, variant styles (filled/outlined), resizable, swipeable on desktop & mobile, loop from video 8 → 1, always start at 1.
    
    Mobile: adjustable visible columns (2.25, 3.25, 4.25) to hint next video.
    
    Glow fix: glow only around video border (not title); add slider to control vertical padding for smooth fade; remove padding limits.
    
    Defaults: all video toggles ON, “Video URL” → “URL”., pop up link is not coming .. make it a link field not text
    
    make it swipeable left and right and follow best practices., make it up to 12 instead of 8 videos
    
    and for the desktop add dropdown similar to mobile asking how many videos to show "Desktop visible columns" starting from 2.25 then 3.35 , 4.25 , 5.25 , make the pop up it the surface layer on website becuase now some element come over the pop up ! 
    
    
    for the arrow navigator , i want simple  arrow left , right .. no need for the circle around it. i need less space ., edit the pop up , make it the first layer on the page! , Make the popup the topmost layer by setting it to position fixed and a very high z-index like 9999.
    Move the popup HTML to the end of the body so it is not inside any parent that has transform or z-index.
    When the popup is open, make background elements not clickable by disabling their pointer events.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slider-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.element_padding_vertical }}px {{ block.settings.element_padding_horizontal }}px;
  }

  .ai-video-slider-{{ ai_gen_id }}__header {
    margin-bottom: {{ block.settings.headline_spacing }}px;
    text-align: {{ block.settings.alignment }};
  }

  {% if block.settings.headline == blank %}
    .ai-video-slider-{{ ai_gen_id }}__header {
      display: none;
      margin-bottom: 0;
    }
  {% endif %}

  .ai-video-slider-{{ ai_gen_id }}__title {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-video-slider-{{ ai_gen_id }}__container {
    position: relative;
    padding-bottom: {{ block.settings.glow_vertical_padding }}px;
    padding-top: {{ block.settings.glow_vertical_padding }}px;
    overflow: hidden;
  }

  .ai-video-slider-{{ ai_gen_id }}__track {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    touch-action: pan-y;
    user-select: none;
    cursor: grab;
    will-change: transform;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.alignment == 'right' %}
      justify-content: flex-end;
    {% elsif block.settings.alignment == 'space-evenly' %}
      justify-content: space-evenly;
    {% endif %}
  }

  .ai-video-slider-{{ ai_gen_id }}__track.dragging {
    cursor: grabbing;
    transition: none;
  }

  .ai-video-slider-{{ ai_gen_id }}__card {
    {% if block.settings.desktop_columns == '2.25' %}
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 1.25)) / 2.25);
    {% elsif block.settings.desktop_columns == '3.25' %}
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 2.25)) / 3.25);
    {% elsif block.settings.desktop_columns == '4.25' %}
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 3.25)) / 4.25);
    {% elsif block.settings.desktop_columns == '5.25' %}
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 4.25)) / 5.25);
    {% endif %}
    cursor: pointer;
    transition: transform 0.3s ease;
    position: relative;
  }

  .ai-video-slider-{{ ai_gen_id }}__card-inner {
    padding: {{ block.settings.card_padding_vertical }}px {{ block.settings.card_padding_horizontal }}px;
  }

  .ai-video-slider-{{ ai_gen_id }}__thumbnail-wrapper {
    position: relative;
    width: 100%;
    overflow: visible;
    {% if block.settings.video_shape == 'circle' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.video_shape == 'portrait' %}
      aspect-ratio: 9 / 16;
    {% elsif block.settings.video_shape == 'landscape' %}
      aspect-ratio: 16 / 9;
    {% elsif block.settings.video_shape == 'square' %}
      aspect-ratio: 1 / 1;
    {% endif %}
  }

  .ai-video-slider-{{ ai_gen_id }}__thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    {% if block.settings.video_shape == 'circle' %}
      border-radius: 50%;
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% elsif block.settings.video_shape == 'portrait' %}
      border-radius: {{ block.settings.border_radius }}px;
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% elsif block.settings.video_shape == 'landscape' %}
      border-radius: {{ block.settings.border_radius }}px;
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% elsif block.settings.video_shape == 'square' %}
      border-radius: {{ block.settings.border_radius }}px;
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    position: relative;
    z-index: 1;
  }

  .ai-video-slider-{{ ai_gen_id }}__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    {% if block.settings.video_shape == 'circle' %}
      border-radius: 50%;
    {% else %}
      border-radius: {{ block.settings.border_radius }}px;
    {% endif %}
    background: {{ block.settings.glow_color }};
    filter: blur({{ block.settings.glow_blur }}px);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
    pointer-events: none;
  }

  .ai-video-slider-{{ ai_gen_id }}__card:hover .ai-video-slider-{{ ai_gen_id }}__glow {
    opacity: 1;
  }

  .ai-video-slider-{{ ai_gen_id }}__play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    pointer-events: none;
    {% unless block.settings.show_play_icon %}
      display: none;
    {% endunless %}
  }

  .ai-video-slider-{{ ai_gen_id }}__play-icon svg {
    width: 50%;
    height: 50%;
    fill: white;
    margin-left: 3px;
  }

  .ai-video-slider-{{ ai_gen_id }}__card-title {
    margin-top: 12px;
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    text-align: center;
    word-wrap: break-word;
  }

  .ai-video-slider-{{ ai_gen_id }}__placeholder {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.video_shape == 'circle' %}
      border-radius: 50%;
    {% else %}
      border-radius: {{ block.settings.border_radius }}px;
    {% endif %}
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    position: relative;
    z-index: 1;
  }

  .ai-video-slider-{{ ai_gen_id }}__placeholder svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  .ai-video-slider-{{ ai_gen_id }}__nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
  }

  .ai-video-slider-{{ ai_gen_id }}__arrow {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
    padding: 0;
  }

  .ai-video-slider-{{ ai_gen_id }}__arrow:hover {
    opacity: 0.6;
  }

  .ai-video-slider-{{ ai_gen_id }}__arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-slider-{{ ai_gen_id }}__arrow svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.arrow_color }};
  }

  .ai-video-slider-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-video-slider-popup-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-video-slider-popup-{{ ai_gen_id }}__content {
    position: relative;
    width: 100%;
    max-width: 90vw;
    max-height: 90vh;
    z-index: 100000;
    {% if block.settings.popup_ratio == '16:9' %}
      aspect-ratio: 16 / 9;
    {% elsif block.settings.popup_ratio == '9:16' %}
      aspect-ratio: 9 / 16;
      max-width: 50vh;
    {% elsif block.settings.popup_ratio == '1:1' %}
      aspect-ratio: 1 / 1;
      max-width: 90vh;
    {% endif %}
  }

  .ai-video-slider-popup-{{ ai_gen_id }}__iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-slider-popup-{{ ai_gen_id }}__close {
    position: absolute;
    top: -40px;
    right: 0;
    background: transparent;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100001;
  }

  body.ai-video-popup-open-{{ ai_gen_id }} {
    overflow: hidden;
  }

  body.ai-video-popup-open-{{ ai_gen_id }} > *:not(.ai-video-slider-popup-{{ ai_gen_id }}) {
    pointer-events: none;
  }

  body.ai-video-popup-open-{{ ai_gen_id }} .ai-video-slider-popup-{{ ai_gen_id }} {
    pointer-events: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-video-slider-{{ ai_gen_id }}__card {
      {% if block.settings.mobile_columns == '2.25' %}
        flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 1.25)) / 2.25);
      {% elsif block.settings.mobile_columns == '3.25' %}
        flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 2.25)) / 3.25);
      {% elsif block.settings.mobile_columns == '4.25' %}
        flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 3.25)) / 4.25);
      {% endif %}
    }

    .ai-video-slider-popup-{{ ai_gen_id }}__content {
      max-width: 95vw;
      max-height: 95vh;
    }
  }
{% endstyle %}

<video-slider-{{ ai_gen_id }} class="ai-video-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.headline != blank %}
    <div class="ai-video-slider-{{ ai_gen_id }}__header">
      <h2 class="ai-video-slider-{{ ai_gen_id }}__title">{{ block.settings.headline }}</h2>
    </div>
  {% endif %}

  <div class="ai-video-slider-{{ ai_gen_id }}__container">
    <div class="ai-video-slider-{{ ai_gen_id }}__track" data-track>
      {% for i in (1..12) %}
        {% liquid
          assign enabled_key = 'video_' | append: i | append: '_enabled'
          assign url_key = 'video_' | append: i | append: '_url'
          assign title_key = 'video_' | append: i | append: '_title'
          assign thumbnail_key = 'video_' | append: i | append: '_thumbnail'
          
          assign enabled = block.settings[enabled_key]
          assign url = block.settings[url_key]
          assign title = block.settings[title_key]
          assign thumbnail = block.settings[thumbnail_key]
        %}

        {% if enabled %}
          <div class="ai-video-slider-{{ ai_gen_id }}__card" data-video-url="{{ url }}">
            <div class="ai-video-slider-{{ ai_gen_id }}__card-inner">
              <div class="ai-video-slider-{{ ai_gen_id }}__thumbnail-wrapper">
                <div class="ai-video-slider-{{ ai_gen_id }}__glow"></div>
                {% if thumbnail %}
                  <img 
                    src="{{ thumbnail | image_url: width: 600 }}" 
                    alt="{{ title | escape }}"
                    class="ai-video-slider-{{ ai_gen_id }}__thumbnail"
                    loading="lazy"
                    draggable="false"
                  >
                {% else %}
                  <div class="ai-video-slider-{{ ai_gen_id }}__placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                {% endif %}
                <div class="ai-video-slider-{{ ai_gen_id }}__play-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              {% if title != blank %}
                <div class="ai-video-slider-{{ ai_gen_id }}__card-title">{{ title }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-video-slider-{{ ai_gen_id }}__nav">
    <button class="ai-video-slider-{{ ai_gen_id }}__arrow ai-video-slider-{{ ai_gen_id }}__arrow--prev" data-prev aria-label="Previous video">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </button>
    <button class="ai-video-slider-{{ ai_gen_id }}__arrow ai-video-slider-{{ ai_gen_id }}__arrow--next" data-next aria-label="Next video">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
      </svg>
    </button>
  </div>
</video-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.startTime = 0;
        this.velocity = 0;
        this.minSwipeDistance = 50;
        this.maxClickTime = 200;
        this.popup = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.cards = Array.from(this.querySelectorAll('.ai-video-slider-{{ ai_gen_id }}__card'));
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');

        if (this.cards.length === 0) return;

        this.createPopup();
        this.setupEventListeners();
        this.updateNavigation();
        this.checkArrowsVisibility();
      }

      createPopup() {
        this.popup = document.createElement('div');
        this.popup.className = 'ai-video-slider-popup-{{ ai_gen_id }}';
        this.popup.setAttribute('data-popup-{{ ai_gen_id }}', '');
        
        this.popup.innerHTML = `
          <div class="ai-video-slider-popup-{{ ai_gen_id }}__content">
            <button class="ai-video-slider-popup-{{ ai_gen_id }}__close" data-close aria-label="Close video">×</button>
            <iframe 
              class="ai-video-slider-popup-{{ ai_gen_id }}__iframe" 
              data-iframe
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
            ></iframe>
          </div>
        `;
        
        document.body.appendChild(this.popup);
        
        this.iframe = this.popup.querySelector('[data-iframe]');
        this.closeBtn = this.popup.querySelector('[data-close]');
      }

      setupEventListeners() {
        this.track.addEventListener('touchstart', this.handleDragStart.bind(this), { passive: true });
        this.track.addEventListener('touchmove', this.handleDragMove.bind(this), { passive: false });
        this.track.addEventListener('touchend', this.handleDragEnd.bind(this));

        this.track.addEventListener('mousedown', this.handleDragStart.bind(this));
        this.track.addEventListener('mousemove', this.handleDragMove.bind(this));
        this.track.addEventListener('mouseup', this.handleDragEnd.bind(this));
        this.track.addEventListener('mouseleave', this.handleDragEnd.bind(this));

        this.cards.forEach(card => {
          card.addEventListener('click', (e) => {
            if (!this.wasDragging) {
              this.openVideo(card);
            }
          });
        });

        this.prevBtn.addEventListener('click', () => this.navigate(-1));
        this.nextBtn.addEventListener('click', () => this.navigate(1));
        
        this.closeBtn.addEventListener('click', () => this.closeVideo());
        this.popup.addEventListener('click', (e) => {
          if (e.target === this.popup) this.closeVideo();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.popup.classList.contains('active')) {
            this.closeVideo();
          }
        });

        window.addEventListener('resize', () => this.checkArrowsVisibility());
      }

      handleDragStart(event) {
        this.isDragging = true;
        this.wasDragging = false;
        this.startPos = this.getPositionX(event);
        this.startTime = Date.now();
        this.track.classList.add('dragging');
        
        if (event.type === 'mousedown') {
          event.preventDefault();
        }
      }

      handleDragMove(event) {
        if (!this.isDragging) return;

        const currentPosition = this.getPositionX(event);
        const diff = currentPosition - this.startPos;

        if (Math.abs(diff) > 5) {
          this.wasDragging = true;
        }

        this.currentTranslate = this.prevTranslate + diff;
        this.setSliderPosition();

        if (event.type === 'touchmove' && Math.abs(diff) > 10) {
          event.preventDefault();
        }
      }

      handleDragEnd(event) {
        if (!this.isDragging) return;

        this.isDragging = false;
        this.track.classList.remove('dragging');

        const movedBy = this.currentTranslate - this.prevTranslate;
        const endTime = Date.now();
        const timeDiff = endTime - this.startTime;
        this.velocity = Math.abs(movedBy / timeDiff);

        const isQuickSwipe = timeDiff < this.maxClickTime && Math.abs(movedBy) > 30;
        const isLongSwipe = Math.abs(movedBy) > this.minSwipeDistance;

        if (isQuickSwipe || isLongSwipe) {
          if (movedBy < 0) {
            this.navigate(1);
          } else if (movedBy > 0) {
            this.navigate(-1);
          }
        } else {
          this.currentTranslate = this.prevTranslate;
          this.setSliderPosition();
        }

        setTimeout(() => {
          this.wasDragging = false;
        }, 10);
      }

      getPositionX(event) {
        return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
      }

      setSliderPosition() {
        this.track.style.transform = `translateX(${this.currentTranslate}px)`;
      }

      navigate(direction) {
        this.currentIndex += direction;
        
        if (this.currentIndex < 0) {
          this.currentIndex = this.cards.length - 1;
        } else if (this.currentIndex >= this.cards.length) {
          this.currentIndex = 0;
        }
        
        this.setPositionByIndex();
      }

      setPositionByIndex() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        this.currentTranslate = -this.currentIndex * (cardWidth + gap);
        this.prevTranslate = this.currentTranslate;
        this.setSliderPosition();
        this.updateNavigation();
      }

      updateNavigation() {
        this.prevBtn.disabled = false;
        this.nextBtn.disabled = false;
      }

      checkArrowsVisibility() {
        const containerWidth = this.track.parentElement.offsetWidth;
        const trackWidth = this.track.scrollWidth;
        
        if (trackWidth <= containerWidth) {
          this.prevBtn.style.display = 'none';
          this.nextBtn.style.display = 'none';
        } else {
          this.prevBtn.style.display = 'flex';
          this.nextBtn.style.display = 'flex';
        }
      }

      openVideo(card) {
        const videoUrl = card.dataset.videoUrl;
        if (!videoUrl) return;

        let embedUrl = '';
        
        if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
          const videoId = this.extractYouTubeId(videoUrl);
          embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
        } else if (videoUrl.includes('vimeo.com')) {
          const videoId = videoUrl.split('/').pop().split('?')[0];
          embedUrl = `https://player.vimeo.com/video/${videoId}?autoplay=1`;
        } else {
          embedUrl = videoUrl;
        }

        this.iframe.src = embedUrl;
        this.popup.classList.add('active');
        document.body.classList.add('ai-video-popup-open-{{ ai_gen_id }}');
      }

      closeVideo() {
        this.popup.classList.remove('active');
        this.iframe.src = '';
        document.body.classList.remove('ai-video-popup-open-{{ ai_gen_id }}');
      }

      extractYouTubeId(url) {
        const regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#&?]*).*/;
        const match = url.match(regExp);
        return (match && match[7].length === 11) ? match[7] : '';
      }

      disconnectedCallback() {
        if (this.popup && this.popup.parentNode) {
          this.popup.parentNode.removeChild(this.popup);
        }
        document.body.classList.remove('ai-video-popup-open-{{ ai_gen_id }}');
      }
    }

    if (!customElements.get('video-slider-{{ ai_gen_id }}')) {
      customElements.define('video-slider-{{ ai_gen_id }}', VideoSlider{{ ai_gen_id }});
    }
  })();
</script>

{% schema %}
{
  "name": "Mini video cards slider",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline"
    },
    {
      "type": "range",
      "id": "headline_spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Spacing below headline",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 5,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Headline size",
