{% doc %}
  @prompt
    "Create a responsive 3-column layout that shows product cards similar to this design:
    
    Each card should have a green header bar with:
    
    the original price crossed out ($25, $28, etc.)
    
    the word FREE in bold white font.
    
    Product image centered.
    
    Product name below the image.
    
    White background with slight border and rounded corners.
    
    Should be mobile-responsive, stack into single-column on small screens.
    
    Here's a sample of the items:
    
    Body Buffer – was $25, now FREE.
    
    Scalp Scrubber – was $25, now FREE.
    
    Anti-Chafe Cream – was $28, now FREE.
    
    Make the design flexible so I can add/remove more items easily.", make the card all in 1 row , image are portrait , and remove headline and remove the word "was", make it smaller , all in 1 row full width not swipable, make it 4 instead of 3, make them 2 rows 2 colums, on mobile 2 columns 2 rows
    
    i want to custimize all words

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .free-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    width: 100%;
    margin: 0 auto;
  }

  .free-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    border: 1px solid {{ block.settings.card_border_color }};
    background-color: {{ block.settings.card_background_color }};
    height: 100%;
  }

  .free-product-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background_color }};
    padding: 8px 12px;
    text-align: center;
  }

  .free-product-price-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
    font-size: {{ block.settings.price_font_size }}px;
    margin-right: 8px;
  }

  .free-product-free-text-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.free_text_color }};
    font-weight: bold;
    font-size: {{ block.settings.free_text_font_size }}px;
  }

  .free-product-image-container-{{ ai_gen_id }} {
    padding: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-grow: 1;
  }

  .free-product-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: {{ block.settings.image_height }}px;
    object-fit: contain;
  }

  .free-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .free-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-height: {{ block.settings.image_height }}px;
  }

  .free-product-title-{{ ai_gen_id }} {
    padding: 10px 15px 15px;
    text-align: center;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .free-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: 15px;
    }

    .free-product-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size | minus: 2 }}px;
    }

    .free-product-free-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.free_text_font_size | minus: 2 }}px;
    }

    .free-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | minus: 2 }}px;
    }
  }
{% endstyle %}

<div class="free-products-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..4) %}
    {% assign product_enabled_key = 'product_' | append: i | append: '_enabled' %}
    {% assign product_image_key = 'product_' | append: i | append: '_image' %}
    {% assign product_title_key = 'product_' | append: i | append: '_title' %}
    {% assign product_price_key = 'product_' | append: i | append: '_price' %}
    {% assign product_free_text_key = 'product_' | append: i | append: '_free_text' %}
    
    {% if block.settings[product_enabled_key] %}
      <div class="free-product-card-{{ ai_gen_id }}">
        <div class="free-product-header-{{ ai_gen_id }}">
          <span class="free-product-price-{{ ai_gen_id }}">{{ block.settings[product_price_key] }}</span>
          <span class="free-product-free-text-{{ ai_gen_id }}">{{ block.settings[product_free_text_key] }}</span>
        </div>
        <div class="free-product-image-container-{{ ai_gen_id }}">
          {% if block.settings[product_image_key] != blank %}
            <img 
              src="{{ block.settings[product_image_key] | image_url: width: 400 }}"
              alt="{{ block.settings[product_title_key] }}"
              loading="lazy"
              class="free-product-image-{{ ai_gen_id }}"
              width="{{ block.settings[product_image_key].width }}"
              height="{{ block.settings[product_image_key].height }}"
            >
          {% else %}
            <div class="free-product-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <h3 class="free-product-title-{{ ai_gen_id }}">{{ block.settings[product_title_key] }}</h3>
      </div>
    {% endif %}
  {% endfor %}
</div>

