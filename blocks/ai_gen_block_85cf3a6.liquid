{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-banner-{{ ai_gen_id }} {
    padding: 40px 0;
    background-color: {{ block.settings.section_bg_color }};
    text-align: center;width: 100%;
  }

  .ai-comparison-banner__container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-comparison-banner__header-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-comparison-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .ai-comparison-banner__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-comparison-banner__table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin: 0 auto;
    width: 100%;border-radius: {{ block.settings.table_border_radius }}px;
    box-shadow: {{ block.settings.table_shadow_x }}px {{ block.settings.table_shadow_y }}px {{ block.settings.table_shadow_blur }}px {{ block.settings.table_shadow_color }};
    background-color: {{ block.settings.table_bg_color }};
  }

  .ai-comparison-banner__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_bg_color }};min-width: 600px;
    border: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};border-radius: {{ block.settings.table_border_radius }}px;
  }

  .ai-comparison-banner__image-row-{{ ai_gen_id }} {
    background-color: {{ block.settings.image_row_bg_color }};
  }

  .ai-comparison-banner__image-cell-{{ ai_gen_id }} {
    padding: 20px 15px;
    border-bottom: 1px solid {{ block.settings.cell_border_color }};
    border-left: 1px solid {{ block.settings.cell_border_color }};
    border-right: 1px solid {{ block.settings.cell_border_color }};text-align: center;
    vertical-align: middle;
  }

  .ai-comparison-banner__image-cell-{{ ai_gen_id }}.highlighted {
    background-color: {{ block.settings.highlighted_column_bg }};
    border-left-color: {{ block.settings.highlight_border_color }};
    border-right-color: {{ block.settings.highlight_border_color }};
    border-left-width: 3px;
    border-right-width: 3px;
  }

  .ai-comparison-banner__product-image-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    margin: 0 auto;
    margin-bottom: 15px;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-comparison-banner__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-comparison-banner__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-comparison-banner__image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-comparison-banner__header-cell-{{ ai_gen_id }} {
    padding: 20px 15px;
    background-color: {{ block.settings.header_bg_color }};
    border:2px solid transparent;
    border-bottom: 1px solid {{ block.settings.cell_border_color }};
    border-left: 1px solid {{ block.settings.cell_border_color }};
    border-right: 1px solid {{ block.settings.cell_border_color }};
    position: relative;
    vertical-align: top;
    text-align: center;
  }

  .ai-comparison-banner__header-cell-{{ ai_gen_id }}.highlighted {
    background-color: {{ block.settings.highlighted_column_bg }};
    border-color: {{ block.settings.highlight_border_color }};
    border-width: 3px;border-bottom-width: 1px;
  }

  .ai-comparison-banner__product-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_name_size }}px;
    font-weight: 700;
    color: {{ block.settings.product_name_color }};
    margin: 0 0 15px 0;
    line-height: 1.3;
    text-align: center;
  }

  .ai-comparison-banner__rating-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .ai-comparison-banner__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-comparison-banner__star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 18px;
  }

  .ai-comparison-banner__reviews-{{ ai_gen_id }} {
    font-size:12px;
    color: {{ block.settings.reviews_text_color }};
    font-weight: 500;
  }

  .ai-comparison-banner__cell-{{ ai_gen_id }} {
    padding: 15px;
    border-bottom: 1px solid {{ block.settings.cell_border_color }};
    border-left: 1px solid {{ block.settings.cell_border_color }};
    border-right: 1px solid {{ block.settings.cell_border_color }};
    text-align: center;
    vertical-align: middle;
    font-size: {{ block.settings.cell_font_size }}px;
    position: relative;
    background-color: {{ block.settings.table_bg_color }};
  }

  .ai-comparison-banner__cell-{{ ai_gen_id }}.highlighted {
    background-color: {{ block.settings.highlighted_column_bg }};
    border-left-color: {{ block.settings.highlight_border_color }};
    border-right-color: {{ block.settings.highlight_border_color }};
    border-left-width: 3px;
    border-right-width: 3px;
  }

  .ai-comparison-banner__cell-{{ ai_gen_id }}:last-child.highlighted {
    border-bottom-color: {{ block.settings.highlight_border_color }};border-bottom-width: 3px;
  }

  .ai-comparison-banner__feature-label-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.feature_label_color }};
    background-color: {{ block.settings.feature_bg_color }};
    padding: 15px;
    border-bottom: 1px solid {{ block.settings.cell_border_color }};
    border-left: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};
    text-align: left;
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-comparison-banner__warranty-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.warranty_highlight_color }};
    font-size: 16px;
  }

  .ai-comparison-banner__check-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: {{ block.settings.check_color }};
    border-radius: 50%;
    color: white;
    font-size: 14px;
    font-weight: bold;
  }

  .ai-comparison-banner__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
    font-size: 20px;
    font-weight: bold;}

  .ai-comparison-banner__price-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 16px;
  }

  .ai-comparison-banner__price-highlighted-{{ ai_gen_id }} {
    color: {{ block.settings.price_highlight_color }};}

  .ai-comparison-banner__price-original-{{ ai_gen_id }} {
    text-decoration: line-through;
    color: {{ block.settings.original_price_color }};
    font-size: 14px;
    margin-left: 5px;
  }

  .ai-comparison-banner__free-text-{{ ai_gen_id }} {
    color: {{ block.settings.free_text_color }};
    font-weight: 700;
  }

  @media screen and (max-width: 768px) {
    .ai-comparison-banner-{{ ai_gen_id }} {
      padding: 30px 0;
    }

    .ai-comparison-banner__container-{{ ai_gen_id }} {
      padding: 0 15px;
    }

    .ai-comparison-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | minus: 6 }}px;
    }

    .ai-comparison-banner__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size | minus: 2 }}px;
    }

    .ai-comparison-banner__table-{{ ai_gen_id }} {
      min-width: 500px;
    }

    .ai-comparison-banner__header-cell-{{ ai_gen_id }},
    .ai-comparison-banner__cell-{{ ai_gen_id }},
    .ai-comparison-banner__image-cell-{{ ai_gen_id }} {
      padding: 12px 8px;
    }

    .ai-comparison-banner__product-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_name_size | minus: 2 }}px;
    }

    .ai-comparison-banner__cell-{{ ai_gen_id }},
    .ai-comparison-banner__feature-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.cell_font_size | minus: 2 }}px;
    }

    .ai-comparison-banner__product-image-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-comparison-banner__table-{{ ai_gen_id }} {
      min-width: 400px;
    }

    .ai-comparison-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | minus: 10 }}px;
    }

    .ai-comparison-banner__header-cell-{{ ai_gen_id }},
    .ai-comparison-banner__cell-{{ ai_gen_id }},
    .ai-comparison-banner__image-cell-{{ ai_gen_id }} {
      padding: 10px 6px;
    }

    .ai-comparison-banner__product-image-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }
  }
{% endstyle %}

<div class="ai-comparison-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-banner__container-{{ ai_gen_id }}">
    <div class="ai-comparison-banner__header-{{ ai_gen_id }}">
      {% if block.settings.main_title != blank %}
        <h2 class="ai-comparison-banner__title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-comparison-banner__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-comparison-banner__table-wrapper-{{ ai_gen_id }}">
      <table class="ai-comparison-banner__table-{{ ai_gen_id }}">
        {% if block.settings.show_image_row %}
          <tr class="ai-comparison-banner__image-row-{{ ai_gen_id }}">
            <td class="ai-comparison-banner__feature-label-{{ ai_gen_id }}"></td>
            {% for i in (1..3) %}
              {% assign product_image_key = 'product_' | append: i | append: '_image' %}
              {% assign highlight_key = 'product_' | append: i | append: '_highlight' %}
              <td class="ai-comparison-banner__image-cell-{{ ai_gen_id }} {% if block.settings[highlight_key] %}highlighted{% endif %}">
                <div class="ai-comparison-banner__product-image-{{ ai_gen_id }}">
                  {% if block.settings[product_image_key] %}
                    <img
                      src="{{ block.settings[product_image_key] | image_url: width: 200 }}"
                      alt="{{ block.settings[product_image_key].alt | escape }}"
                      loading="lazy"
                      width="200"
                      height="200"
                    >
                  {% else %}
                    <div class="ai-comparison-banner__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              </td>
            {% endfor %}
          </tr>
        {% endif %}

        <thead>
          <tr>
            <th class="ai-comparison-banner__feature-label-{{ ai_gen_id }}"></th>
            {% for i in (1..3) %}
              {% assign product_name_key = 'product_' | append: i | append: '_name' %}
              {% assign highlight_key = 'product_' | append: i | append: '_highlight' %}
              {% assign show_rating_key = 'product_' | append: i | append: '_show_rating' %}
              {% assign rating_count_key = 'product_' | append: i | append: '_rating_count' %}
              
              <th class="ai-comparison-banner__header-cell-{{ ai_gen_id }} {% if block.settings[highlight_key] %}highlighted{% endif %}">
                <div class="ai-comparison-banner__product-name-{{ ai_gen_id }}">
                  {{ block.settings[product_name_key] }}
                </div>
                {% if block.settings[show_rating_key] %}
                  <div class="ai-comparison-banner__rating-{{ ai_gen_id }}">
                    <div class="ai-comparison-banner__stars-{{ ai_gen_id }}">
                      {% for star in (1..5) %}
                        <span class="ai-comparison-banner__star-{{ ai_gen_id }}">★</span>
                      {% endfor %}
                    </div>
                    <div class="ai-comparison-banner__reviews-{{ ai_gen_id }}">
                      {{ block.settings[rating_count_key] }} {{ block.settings.reviews_text }}
                    </div>
                  </div>
                {% endif %}
              </th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row_num in (1..6) %}
            {% assign row_feature_key = 'row_' | append: row_num | append: '_feature' %}
            <tr>
              <td class="ai-comparison-banner__feature-label-{{ ai_gen_id }}">
                {{ block.settings[row_feature_key] }}
              </td>
              {% for col in (1..3) %}
                {% assign cell_key = 'row_' | append: row_num | append: '_col_' | append: col %}
                {% assign cell_type_key = 'row_' | append: row_num | append: '_col_' | append: col | append: '_type' %}
                {% assign original_price_key = 'row_' | append: row_num | append: '_col_' | append: col | append: '_original' %}
                {% assign free_text_key = 'row_' | append: row_num | append: '_col_' | append: col | append: '_free_text' %}
                {% assign highlight_key = 'product_' | append: col | append: '_highlight' %}
                
                <td class="ai-comparison-banner__cell-{{ ai_gen_id }} {% if block.settings[highlight_key] %}highlighted{% endif %}">
                  {% assign cell_type = block.settings[cell_type_key] %}
                  {% assign cell_content = block.settings[cell_key] %}
                  {% assign original_price = block.settings[original_price_key] %}
                  {% assign free_text = block.settings[free_text_key] %}
                  {% case cell_type %}
                    {% when 'check' %}
                      <span class="ai-comparison-banner__check-{{ ai_gen_id }}">✓</span>
                    {% when 'cross' %}
                      <span class="ai-comparison-banner__cross-{{ ai_gen_id }}">✕</span>
                    {% when 'warranty' %}
                      <span class="ai-comparison-banner__warranty-{{ ai_gen_id }}">{{ cell_content }}</span>
                    {% when 'price' %}
                      <span class="ai-comparison-banner__price-{{ ai_gen_id }} {% if block.settings[highlight_key] %}ai-comparison-banner__price-highlighted-{{ ai_gen_id }}{% endif %}">
                        {{ cell_content }}
                        {% if original_price != blank %}
                          <span class="ai-comparison-banner__price-original-{{ ai_gen_id }}">{{ original_price }}</span>
                        {% endif %}
                      </span>
                    {% when 'free' %}
                      <span class="ai-comparison-banner__free-text-{{ ai_gen_id }}">
                        {% if free_text != blank %}{{ free_text }}{% else %}FREE{% endif %}
                {% if original_price != blank %}
                          <span class="ai-comparison-banner__price-original-{{ ai_gen_id }}">{{ original_price }}</span>
                        {% endif %}
                      </span>
                    {% else %}
                      {{ cell_content }}
                  {% endcase %}
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

