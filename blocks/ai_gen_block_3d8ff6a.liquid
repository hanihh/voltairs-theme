{% doc %}
  @prompt
    i want quote flied, i want it to be 1 tiny compact raw, i want contral for everything from width size to alligment to evrything, i want a Quote text field that i can controll Bold , italic underline etc, add margin control
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-quote-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    margin: {{ block.settings.margin_top }}px {{ block.settings.margin_right }}px {{ block.settings.margin_bottom }}px {{ block.settings.margin_left }}px;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-quote-container-{{ ai_gen_id }} {
    display: inline-block;
    width: {% if block.settings.width_type == 'full' %}100%{% else %}auto{% endif %};
    max-width: {{ block.settings.max_width }}px;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
    background-color: {{ block.settings.background_color }};
    border-left: {{ block.settings.border_left_width }}px solid {{ block.settings.border_left_color }};
    border-right: {{ block.settings.border_right_width }}px solid {{ block.settings.border_right_color }};
    border-top: {{ block.settings.border_top_width }}px solid {{ block.settings.border_top_color }};
    border-bottom: {{ block.settings.border_bottom_width }}px solid {{ block.settings.border_bottom_color }};
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.enable_shadow %}
      box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    {% endif %}
  }

  .ai-quote-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-quote-text-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  .ai-quote-text-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-quote-text-{{ ai_gen_id }} u {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-quote-wrapper-{{ ai_gen_id }} {
      margin: {{ block.settings.margin_top | times: 0.7 }}px {{ block.settings.margin_right | times: 0.7 }}px {{ block.settings.margin_bottom | times: 0.7 }}px {{ block.settings.margin_left | times: 0.7 }}px;
    }

    .ai-quote-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_right | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_left | times: 0.7 }}px;
    }

    .ai-quote-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-quote-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-quote-container-{{ ai_gen_id }}">
    {% if block.settings.quote_text != blank %}
      <div class="ai-quote-text-{{ ai_gen_id }}">
        {{ block.settings.quote_text }}
      </div>
    {% endif %}
  </div>
</div>

