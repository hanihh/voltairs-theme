{% doc %}
  @prompt
    Banner:
    Design a clean, informative ingredients banner section for a men's skincare or body care brand. The layout should include:
    
    ✅ Title Area:
    
    Small green subtitle: “The Australian Way”
    
    Main bold headline: “Natural Ingredients that are proven to work”
    
    Centered alignment
    
    ✅ Grid of 6 Ingredients (2 Rows x 3 Columns or Responsive Stack on Mobile):
    For each ingredient card:
    
    Circular image icon at the top (natural-looking photo)
    
    Bold title underneath (e.g., “Shea Butter”)
    
    One-line description in smaller text (e.g., “Soothes irritated skin and creates a moisture locking barrier…”)
    
    All cards should have subtle drop shadows and clean spacing
    
    ✅ Ingredients to include:
    
    Shea Butter – Soothes irritated skin and creates a moisture-locking barrier that blocks bacteria.
    
    Aloe Vera – Calms inflammation and supports skin healing, helping keep pores clean.
    
    Activated Charcoal – Draws out dirt, sweat, and toxins that feed odor-causing bacteria.
    
    Coconut Oil – Kills odor-causing bacteria on the skin with its antimicrobial properties.
    
    Bergamot Fruit Oil – Provides a fresh citrus scent while naturally neutralizing bacteria.
    
    Cedarwood Oil – Adds a clean, masculine aroma and balances oil production.
    
    ✅ Design Style:
    
    White background
    
    Rounded image icons
    
    Font: modern and clean (like Poppins or Helvetica)
    
    Balanced whitespace, light drop shadows
    
    Responsive layout (mobile friendly), give me the option to add up to 22 ingredients and pop up option for learn more for each ingedients, and give me abilty to show or hide each element, pop up botton is not working, and make the learn more as text with link with arrow sign/icon not as button with BG, i need to be able to change image style from circle to landscape to auto to portrait and make it fit full width  ... etc, give me abitly to change shadow or remove it , and add boarder and control it color size and rounded, i need to be able to change shadow color

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.ingredients-banner-{{ ai_gen_id }} {
  padding: 60px 20px;
  background-color: {{ block.settings.background_color }};
}

.ingredients-banner__header-{{ ai_gen_id }} {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 50px;
}

.ingredients-banner__subtitle-{{ ai_gen_id }} {
  font-size: 14px;
  color: {{ block.settings.subtitle_color }};
  margin-bottom: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  display: {% if block.settings.show_subtitle %}block{% else %}none{% endif %};
}

.ingredients-banner__title-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px;
  color: {{ block.settings.heading_color }};
  margin: 0;
  font-weight: 700;
  line-height: 1.2;
  display: {% if block.settings.show_heading %}block{% else %}none{% endif %};
}

.ingredients-grid-{{ ai_gen_id }} {
  display: grid;
  grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.ingredient-card-{{ ai_gen_id }} {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 25px 20px;
  background-color: {{ block.settings.card_background_color }};
  border-radius: {{ block.settings.card_border_radius }}px;
  box-shadow: {% if block.settings.show_card_shadow %}0 {{ block.settings.shadow_vertical_offset }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }}{% else %}none{% endif %};
  transition: transform 0.3s ease;
  position: relative;
  border: {% if block.settings.show_card_border %}{{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }}{% else %}none{% endif %};
}

.ingredient-image-wrapper-{{ ai_gen_id }} {
  width: 100%;
  margin-bottom: 15px;
  box-shadow: {% if block.settings.show_image_shadow %}0 {{ block.settings.image_shadow_vertical_offset }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_color }}{% else %}none{% endif %};
  overflow: hidden;
  position: relative;
  border: {% if block.settings.show_image_border %}{{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }}{% else %}none{% endif %};
}

.ingredient-image-wrapper-{{ ai_gen_id }}.circle {
  width: {{ block.settings.image_size }}px;
  height: {{ block.settings.image_size }}px;
  border-radius: 50%;
}

.ingredient-image-wrapper-{{ ai_gen_id }}.landscape {
  width: 100%;
  height: 0;
  padding-bottom: 56.25%; /* 16:9 aspect ratio */
  border-radius: {{ block.settings.image_border_radius }}px;
}

.ingredient-image-wrapper-{{ ai_gen_id }}.portrait {
  width: 100%;
  height: 0;
  padding-bottom: 133.33%; /* 3:4 aspect ratio */
  border-radius: {{ block.settings.image_border_radius }}px;
}

.ingredient-image-wrapper-{{ ai_gen_id }}.auto {
  width: 100%;
  height: auto;
  border-radius: {{ block.settings.image_border_radius }}px;
}

.ingredient-image-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ingredient-image-wrapper-{{ ai_gen_id }}.landscape .ingredient-image-{{ ai_gen_id }},
.ingredient-image-wrapper-{{ ai_gen_id }}.portrait .ingredient-image-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.ingredient-image-placeholder-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f4f4f4;
}

.ingredient-image-wrapper-{{ ai_gen_id }}.circle .ingredient-image-placeholder-{{ ai_gen_id }} {
  border-radius: 50%;
}

.ingredient-image-placeholder-{{ ai_gen_id }} svg {
  width: 60%;
  height: 60%;
}

.ingredient-title-{{ ai_gen_id }} {
  font-size: 18px;
  font-weight: 600;
  color: {{ block.settings.ingredient_title_color }};
  margin: 0 0 8px;
}

.ingredient-description-{{ ai_gen_id }} {
  font-size: 14px;
  line-height: 1.5;
  color: {{ block.settings.ingredient_text_color }};
  margin: 0;
}

.ingredient-learn-more-{{ ai_gen_id }} {
  margin-top: 10px;
  font-size: 14px;
  color: {{ block.settings.learn_more_color }};
  text-decoration: none;
  cursor: pointer;
  display: {% if block.settings.show_learn_more %}inline-flex{% else %}none{% endif %};
  align-items: center;
  gap: 5px;
}

.ingredient-learn-more-{{ ai_gen_id }}:hover {
  text-decoration: underline;
}

.ingredient-learn-more-icon-{{ ai_gen_id }} {
  width: 14px;
  height: 14px;
  transition: transform 0.2s ease;
}

.ingredient-learn-more-{{ ai_gen_id }}:hover .ingredient-learn-more-icon-{{ ai_gen_id }} {
  transform: translateX(3px);
}

.ingredient-popup-{{ ai_gen_id }} {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.ingredient-popup-{{ ai_gen_id }}.active {
  opacity: 1;
  visibility: visible;
}

.ingredient-popup-content-{{ ai_gen_id }} {
  background-color: {{ block.settings.popup_background_color }};
  border-radius: {{ block.settings.popup_border_radius }}px;
  padding: 30px;
  max-width: 500px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  position: relative;
  box-shadow: {% if block.settings.show_popup_shadow %}0 {{ block.settings.popup_shadow_vertical_offset }}px {{ block.settings.popup_shadow_blur }}px {{ block.settings.popup_shadow_color }}{% else %}none{% endif %};
  border: {% if block.settings.show_popup_border %}{{ block.settings.popup_border_width }}px solid {{ block.settings.popup_border_color }}{% else %}none{% endif %};
}

.ingredient-popup-close-{{ ai_gen_id }} {
  position: absolute;
  top: 15px;
  right: 15px;
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: {{ block.settings.ingredient_title_color }};
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  padding: 0;
}

.ingredient-popup-image-{{ ai_gen_id }} {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  overflow: hidden;
  border: {% if block.settings.show_image_border %}{{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }}{% else %}none{% endif %};
}

.ingredient-popup-image-{{ ai_gen_id }}.circle {
  border-radius: 50%;
}

.ingredient-popup-image-{{ ai_gen_id }}.landscape,
.ingredient-popup-image-{{ ai_gen_id }}.portrait,
.ingredient-popup-image-{{ ai_gen_id }}.auto {
  width: 100%;
  max-width: 300px;
  height: auto;
  border-radius: {{ block.settings.image_border_radius }}px;
}

.ingredient-popup-image-{{ ai_gen_id }} img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ingredient-popup-title-{{ ai_gen_id }} {
  font-size: 22px;
  font-weight: 600;
  color: {{ block.settings.ingredient_title_color }};
  margin: 0 0 15px;
  text-align: center;
}

.ingredient-popup-description-{{ ai_gen_id }} {
  font-size: 16px;
  line-height: 1.6;
  color: {{ block.settings.ingredient_text_color }};
}

@media screen and (max-width: 990px) {
  .ingredients-grid-{{ ai_gen_id }} {
    grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
  }
}

@media screen and (max-width: 749px) {
  .ingredients-grid-{{ ai_gen_id }} {
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: 20px;
  }
  
  .ingredients-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size | times: 0.8 }}px;
  }
  
  .ingredient-card-{{ ai_gen_id }} {
    padding: 20px 15px;
  }
  
  .ingredient-popup-content-{{ ai_gen_id }} {
    padding: 20px;
  }
}
{% endstyle %}

<ingredients-block-{{ ai_gen_id }} class="ingredients-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ingredients-banner__header-{{ ai_gen_id }}">
    <div class="ingredients-banner__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    <h2 class="ingredients-banner__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  </div>
  
  <div class="ingredients-grid-{{ ai_gen_id }}">
    {% for i in (1..22) %}
      {% liquid
        assign ingredient_enabled_key = 'ingredient_' | append: i | append: '_enabled'
        assign ingredient_image_key = 'ingredient_' | append: i | append: '_image'
        assign ingredient_title_key = 'ingredient_' | append: i | append: '_title'
        assign ingredient_description_key = 'ingredient_' | append: i | append: '_description'
        assign ingredient_full_description_key = 'ingredient_' | append: i | append: '_full_description'
        
        assign ingredient_enabled = block.settings[ingredient_enabled_key]
        assign ingredient_image = block.settings[ingredient_image_key]
        assign ingredient_title = block.settings[ingredient_title_key]
        assign ingredient_description = block.settings[ingredient_description_key]
        assign ingredient_full_description = block.settings[ingredient_full_description_key]
      %}
      
      {% if ingredient_enabled and ingredient_title != blank %}
        <div class="ingredient-card-{{ ai_gen_id }}" data-ingredient-id="{{ i }}">
          <div class="ingredient-image-wrapper-{{ ai_gen_id }} {{ block.settings.image_style }}">
            {% if ingredient_image != blank %}
              <img 
                src="{{ ingredient_image | image_url: width: 400 }}"
                alt="{{ ingredient_title }}"
                loading="lazy"
                width="400"
                height="400"
                class="ingredient-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ingredient-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <h3 class="ingredient-title-{{ ai_gen_id }}">{{ ingredient_title }}</h3>
          <p class="ingredient-description-{{ ai_gen_id }}">{{ ingredient_description }}</p>
          <a href="#" class="ingredient-learn-more-{{ ai_gen_id }}" data-ingredient-id="{{ i }}">
            {{ block.settings.learn_more_text }}
            <svg class="ingredient-learn-more-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  
  <div class="ingredient-popup-{{ ai_gen_id }}">
    <div class="ingredient-popup-content-{{ ai_gen_id }}">
      <button type="button" class="ingredient-popup-close-{{ ai_gen_id }}" aria-label="Close popup">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="ingredient-popup-image-{{ ai_gen_id }} {{ block.settings.image_style }}">
        <img src="" alt="" class="popup-image">
      </div>
      <h3 class="ingredient-popup-title-{{ ai_gen_id }}"></h3>
      <div class="ingredient-popup-description-{{ ai_gen_id }}"></div>
    </div>
  </div>
</ingredients-block-{{ ai_gen_id }}>

<script>
  class IngredientsBlock extends HTMLElement {
    constructor() {
      super();
      this.ingredientCards = this.querySelectorAll('.ingredient-card-{{ ai_gen_id }}');
      this.popup = this.querySelector('.ingredient-popup-{{ ai_gen_id }}');
      this.popupContent = this.querySelector('.ingredient-popup-content-{{ ai_gen_id }}');
      this.popupClose = this.querySelector('.ingredient-popup-close-{{ ai_gen_id }}');
      this.popupImage = this.querySelector('.ingredient-popup-image-{{ ai_gen_id }} img');
      this.popupTitle = this.querySelector('.ingredient-popup-title-{{ ai_gen_id }}');
      this.popupDescription = this.querySelector('.ingredient-popup-description-{{ ai_gen_id }}');
      this.popupImageContainer = this.querySelector('.ingredient-popup-image-{{ ai_gen_id }}');
      
      this.ingredientData = [
        {% for i in (1..22) %}
          {% liquid
            assign ingredient_enabled_key = 'ingredient_' | append: i | append: '_enabled'
            assign ingredient_image_key = 'ingredient_' | append: i | append: '_image'
            assign ingredient_title_key = 'ingredient_' | append: i | append: '_title'
            assign ingredient_description_key = 'ingredient_' | append: i | append: '_description'
            assign ingredient_full_description_key = 'ingredient_' | append: i | append: '_full_description'
            
            assign ingredient_enabled = block.settings[ingredient_enabled_key]
            assign ingredient_image = block.settings[ingredient_image_key]
            assign ingredient_title = block.settings[ingredient_title_key]
            assign ingredient_full_description = block.settings[ingredient_full_description_key]
          %}
          
          {% if ingredient_enabled and ingredient_title != blank %}
            {
              id: {{ i }},
              title: {{ ingredient_title | json }},
              image: {% if ingredient_image != blank %}{{ ingredient_image | image_url: width: 400 | json }}{% else %}null{% endif %},
              fullDescription: {{ ingredient_full_description | json }}
            },
          {% endif %}
        {% endfor %}
      ];
      
      this.init();
    }
    
    init() {
      this.setupEventListeners();
    }
    
    setupEventListeners() {
      // Learn more links
      this.querySelectorAll('.ingredient-learn-more-{{ ai_gen_id }}').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const ingredientId = link.getAttribute('data-ingredient-id');
          this.openPopup(ingredientId);
        });
      });
      
      // Close popup
      this.popupClose.addEventListener('click', () => {
        this.closePopup();
      });
      
      // Close popup when clicking outside
      this.popup.addEventListener('click', (e) => {
        if (e.target === this.popup) {
          this.closePopup();
        }
      });
      
      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.popup.classList.contains('active')) {
          this.closePopup();
        }
      });
    }
    
    openPopup(ingredientId) {
      const ingredient = this.ingredientData.find(item => item.id == ingredientId);
      
      if (ingredient) {
        // Set popup content
        this.popupTitle.textContent = ingredient.title;
        
        if (ingredient.image) {
          this.popupImage.src = ingredient.image;
          this.popupImage.alt = ingredient.title;
          this.popupImageContainer.style.display = 'block';
        } else {
          this.popupImageContainer.style.display = 'none';
        }
        
        this.popupDescription.innerHTML = ingredient.fullDescription;
        
        // Show popup
        this.popup.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    }
    
    closePopup() {
      this.popup.classList.remove('active');
      document.body.style.overflow = '';
    }
  }
  
  customElements.define('ingredients-block-{{ ai_gen_id }}', IngredientsBlock);
</script>

