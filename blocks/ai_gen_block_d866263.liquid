{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-offer-timer-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: {{ block.settings.timer_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.timer_text_color }};
    background: {{ block.settings.timer_background_color }};
    padding: {{ block.settings.timer_padding }}px 12px;
    border-radius: {{ block.settings.timer_border_radius }}px;
    width: 100%;
    text-align: center;
    box-sizing: border-box;
    margin-bottom: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px;
  }

  .ai-timer-value-{{ ai_gen_id }} {
    color: {{ block.settings.countdown_color }};
    font-weight: 700;
  }
  
  .ai-after-timer-text-{{ ai_gen_id }} {
    color: {{ block.settings.after_timer_text_color }};
  }

  .ai-stock-bar-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    height: {{ block.settings.progress_bar_height }}px;
    border: {{ block.settings.progress_bar_border_width }}px solid {{ block.settings.progress_bar_border_color }};
    border-radius: {{ block.settings.progress_bar_border_radius }}px;
    overflow: hidden;
    box-sizing: border-box;
    font-size: {{ block.settings.progress_bar_font_size }}px;
    font-weight: 600;
  }

  .ai-sold-bar-{{ ai_gen_id }} {
    background: {{ block.settings.sold_bar_color }};
    color: {{ block.settings.sold_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    transition: width 0.3s ease;
    width: {{ block.settings.sold_percentage }}%;
  }

  .ai-remaining-bar-{{ ai_gen_id }} {
    background: {{ block.settings.remaining_bar_color }};
    color: {{ block.settings.remaining_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex-grow: 1;
  }

  .ai-percent-{{ ai_gen_id }} {
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .ai-offer-timer-{{ ai_gen_id }} {
      font-size: {{ block.settings.timer_font_size | times: 0.9 }}px;
    }
    
    .ai-stock-bar-{{ ai_gen_id }} {
      font-size: {{ block.settings.progress_bar_font_size | times: 0.8 }}px;
      height: {{ block.settings.progress_bar_height | times: 0.9 }}px;
    }
  }
{% endstyle %}

<offer-timer-{{ ai_gen_id }}
  class="ai-offer-timer-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-offer-timer-{{ ai_gen_id }}">
    {{ block.settings.timer_text }}
    <span id="ai-countdown-timer-{{ ai_gen_id }}" class="ai-timer-value-{{ ai_gen_id }}">
      {% assign hours = block.settings.countdown_hours %}
      {% assign minutes = block.settings.countdown_minutes %}
      {% assign seconds = block.settings.countdown_seconds %}
      {% if hours < 10 %}0{% endif %}{{ hours }}:{% if minutes < 10 %}0{% endif %}{{ minutes }}:{% if seconds < 10 %}0{% endif %}{{ seconds }}
    </span>
    {% if block.settings.after_timer_text != blank %}
      <span class="ai-after-timer-text-{{ ai_gen_id }}">{{ block.settings.after_timer_text }}</span>
    {% endif %}
  </div>

  <div class="ai-stock-bar-{{ ai_gen_id }}">
    <div class="ai-sold-bar-{{ ai_gen_id }}">
      <span class="ai-percent-{{ ai_gen_id }}">{{ block.settings.sold_percentage }}%</span>
      <span>{{ block.settings.sold_text }}</span>
    </div>
    <div class="ai-remaining-bar-{{ ai_gen_id }}">
      <span class="ai-percent-{{ ai_gen_id }}">{{ 100 | minus: block.settings.sold_percentage }}%</span>
      <span>{{ block.settings.remaining_text }}</span>
    </div>
  </div>
</offer-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class OfferTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timerEl = null;
        this.totalSeconds = 0;
        this.intervalId = null;
      }

      connectedCallback() {
        this.timerEl = this.querySelector('#ai-countdown-timer-{{ ai_gen_id }}');
        if (!this.timerEl) return;

        const hours = {{ block.settings.countdown_hours }};
        const minutes = {{ block.settings.countdown_minutes }};
        const seconds = {{ block.settings.countdown_seconds }};
        
        this.totalSeconds = hours * 3600 + minutes * 60 + seconds;
        this.startTimer();
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }

      formatNumber(num) {
        return num.toString().padStart(2, '0');
      }

      updateDisplay() {
        const hours = Math.floor(this.totalSeconds / 3600);
        const minutes = Math.floor((this.totalSeconds % 3600) / 60);
        const seconds = this.totalSeconds % 60;
        
        this.timerEl.textContent = `${this.formatNumber(hours)}:${this.formatNumber(minutes)}:${this.formatNumber(seconds)}`;
      }

      tick() {
        this.updateDisplay();
        if (this.totalSeconds > 0) {
          this.totalSeconds--;
        } else {
          clearInterval(this.intervalId);
          {% if block.settings.show_expired_message %}
            this.timerEl.textContent = '{{ block.settings.expired_message }}';
          {% endif %}
        }
      }

      startTimer() {
        this.updateDisplay();
        this.intervalId = setInterval(() => this.tick(), 1000);
      }
    }

    customElements.define('offer-timer-{{ ai_gen_id }}', OfferTimer{{ ai_gen_id }});
  })();
</script>

