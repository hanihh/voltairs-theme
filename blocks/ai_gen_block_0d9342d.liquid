{% doc %}
  @prompt
    I'd like your help designing a clean and modern "Trust Badge Bar" for our product pages. This section should visually highlight 4–5 key selling points in a horizontal layout (like icons + short text).
    
    Content to include:
    
    :blue_heart: Dedicated Support
    
    :check: 1-Year Warranty
    
    :lock: Secure Checkout
    
    :repeat: 60-Day Returns
    
    :truck: Free Tracked Shipping
    
    Style Preferences:
    
    Rounded pill-style containers for each item
    
    Light background (white or light gray)
    
    Minimal icon next to each text (solid, clean line icons)
    
    Font consistent with our brand (e.g., Inter or similar)
    
    Responsive layout (mobile friendly)
    
    This section should blend well with our product detail page and feel premium but not distracting.
    
    Let me know if you need references or if you can mock this up for both desktop and mobile views.
    
    Thanks!, i want ability to add my icons "upload image" or add emoji and i want abilite to add up to 20 items

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .trust-badge-bar-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding }}px 0;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.container_border_radius }}px;
  }

  .trust-badge-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: nowrap;
    justify-content: {{ block.settings.alignment }};
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    padding: 0 {{ block.settings.padding }}px;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE and Edge */
  }

  .trust-badge-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    padding: {{ block.settings.badge_padding }}px {{ block.settings.badge_padding | times: 1.5 }}px;
    background-color: {{ block.settings.badge_background_color }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    min-width: max-content;
    box-shadow: {{ block.settings.show_shadow | default: false | ternary: '0 2px 5px rgba(0,0,0,0.1)', 'none' }};
  }

  .trust-badge-icon-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 8px;
    font-size: {{ block.settings.icon_size }}px;
  }

  .trust-badge-icon-image-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
  }

  .trust-badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
  }

  @media screen and (max-width: 749px) {
    .trust-badge-container-{{ ai_gen_id }} {
      justify-content: flex-start;
      padding: 0 {{ block.settings.padding | divided_by: 2 }}px;
    }
    
    .trust-badge-item-{{ ai_gen_id }} {
      padding: {{ block.settings.badge_padding | times: 0.8 }}px {{ block.settings.badge_padding | times: 1.2 }}px;
    }
    
    .trust-badge-icon-{{ ai_gen_id }} {
      font-size: {{ block.settings.icon_size | times: 0.9 }}px;
    }
    
    .trust-badge-icon-image-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }
    
    .trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="trust-badge-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="trust-badge-container-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% assign badge_text_key = 'badge_' | append: i | append: '_text' %}
      {% assign badge_icon_key = 'badge_' | append: i | append: '_icon' %}
      {% assign badge_image_key = 'badge_' | append: i | append: '_image' %}
      
      {% assign badge_text = block.settings[badge_text_key] %}
      {% assign badge_icon = block.settings[badge_icon_key] %}
      {% assign badge_image = block.settings[badge_image_key] %}
      
      {% if badge_text != blank %}
        <div class="trust-badge-item-{{ ai_gen_id }}">
          <div class="trust-badge-icon-{{ ai_gen_id }}">
            {% if badge_image != blank %}
              <img 
                src="{{ badge_image | image_url: width: 50 }}" 
                alt="{{ badge_text }}" 
                loading="lazy" 
                width="{{ block.settings.icon_size }}" 
                height="{{ block.settings.icon_size }}" 
                class="trust-badge-icon-image-{{ ai_gen_id }}"
              >
            {% elsif badge_icon != blank %}
              {{ badge_icon }}
            {% endif %}
          </div>
          <div class="trust-badge-text-{{ ai_gen_id }}">{{ badge_text }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

