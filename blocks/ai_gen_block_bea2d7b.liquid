{% doc %}
  @prompt
    Create a clean and soft carousel banner for a beauty or slimming device, showing different body areas where the device can be used. The banner should have 5 separate vertical tiles or frames side-by-side, each featuring a woman in neutral-toned activewear using a white and red handheld device on the following areas:
    
    Abdomen – showing the lower belly being treated with the device
    
    Butt – device applied on the side of the buttocks
    
    Legs – seated position, applying device to the thigh
    
    Arms – applying the device under the upper arm
    
    Love Handles – treating the side waist/lower back area
    
    Background should be soft pastel or light nude with minimal text above the images saying: "Target Every Inch" in stylish typography. Each frame should be labeled clearly with the corresponding body part (e.g., "Abdomen", "Butt", etc.) in simple, modern font below each image. Overall style should be clean, modern, and professional with natural lighting., add on edits  auto slider with timer option, give me option to run on /off arrows for navigation or outo slider, add option to on /off the dots of the slider, make the Label content editable, make Slides media to be image or uploaded video, enable uploading videos, make the  Video can run outo play or with click, remove Video from Media type, make a background option for Label content

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.beauty-carousel-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
  background-color: {{ block.settings.background_color }};
  padding: {{ block.settings.padding }}px 0;
  border-radius: {{ block.settings.border_radius }}px;
}

.beauty-carousel__title-{{ ai_gen_id }} {
  text-align: center;
  margin-bottom: 30px;
  font-size: {{ block.settings.title_size }}px;
  color: {{ block.settings.text_color }};
  font-weight: 500;
}

.beauty-carousel__track-{{ ai_gen_id }} {
  display: flex;
  transition: transform 0.5s ease-in-out;
  gap: {{ block.settings.gap }}px;
}

.beauty-carousel__slide-{{ ai_gen_id }} {
  flex: 0 0 calc((100% - {{ block.settings.gap }}px * ({{ block.settings.visible_slides }} - 1)) / {{ block.settings.visible_slides }});
  max-width: calc((100% - {{ block.settings.gap }}px * ({{ block.settings.visible_slides }} - 1)) / {{ block.settings.visible_slides }});
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border-radius: {{ block.settings.item_border_radius }}px;
  overflow: hidden;
}

.beauty-carousel__media-container-{{ ai_gen_id }} {
  width: 100%;
  position: relative;
  padding-bottom: 150%; /* 2:3 aspect ratio */
  background-color: {{ block.settings.item_background_color }};
  border-radius: {{ block.settings.item_border_radius }}px;overflow: hidden;
}

.beauty-carousel__image-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.beauty-carousel__placeholder-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: {{ block.settings.item_background_color }};
}

.beauty-carousel__placeholder-{{ ai_gen_id }} svg {
  width: 60%;
  height: 60%;
  opacity: 0.2;
}

.beauty-carousel__label-{{ ai_gen_id }} {
  margin-top: 15px;
  font-size: {{ block.settings.label_size }}px;
  color: {{ block.settings.text_color }};
  text-align: center;
  font-weight: 400;
  padding: 5px 10px;
  background-color: {{ block.settings.label_background_color }};
  border-radius: {{ block.settings.label_border_radius }}px;
}

.beauty-carousel__nav-{{ ai_gen_id }} {
  display: {% if block.settings.show_navigation %}flex{% else %}none{% endif %};
  justify-content: center;
  margin-top: 20px;gap: 10px;
}

.beauty-carousel__nav-button-{{ ai_gen_id }} {
  background-color: {{ block.settings.nav_button_color }};
  color: {{ block.settings.nav_button_text_color }};
  border: none;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.3s;
}

.beauty-carousel__nav-button-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.nav_button_hover_color }};
}

.beauty-carousel__dots-{{ ai_gen_id }} {
  display: {% if block.settings.show_dots %}flex{% else %}none{% endif %};
  justify-content: center;
  gap: 8px;
  margin-top: 20px;
}

.beauty-carousel__dot-{{ ai_gen_id }} {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: {{ block.settings.dot_color }};
  opacity: 0.5;
  cursor: pointer;
  transition: opacity 0.3s, transform 0.3s;
}

.beauty-carousel__dot-{{ ai_gen_id }}.active {
  opacity: 1;
  transform: scale(1.2);
}

.beauty-carousel__controls-{{ ai_gen_id }} {
  display: {% if block.settings.show_autoplay_controls %}flex{% else %}none{% endif %};
  align-items: center;
  justify-content: center;
  margin-top: 10px;
  gap: 8px;
}

.beauty-carousel__autoplay-button-{{ ai_gen_id }} {
  background-color: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: {{ block.settings.text_color }};
  padding: 5px;
}

@media screen and (max-width: 749px) {
  .beauty-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.gap }}px * ({{ block.settings.visible_slides_mobile }} - 1)) / {{ block.settings.visible_slides_mobile }});
    max-width: calc((100% - {{ block.settings.gap }}px * ({{ block.settings.visible_slides_mobile }} - 1)) / {{ block.settings.visible_slides_mobile }});
  }
  
  .beauty-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size | times: 0.8 }}px;margin-bottom: 20px;
  }
  
  .beauty-carousel__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size | times: 0.9 }}px;
  }
}
{% endstyle %}

<div class="beauty-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h2 class="beauty-carousel__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}
  
  <beauty-device-carousel-{{ ai_gen_id }} 
    class="beauty-carousel__container-{{ ai_gen_id }}" 
    data-autoplay="{{ block.settings.autoplay }}" 
    data-interval="{{ block.settings.autoplay_speed }}"><div class="beauty-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign label_key = 'label_' | append: i %}
        
        {% assign image = block.settings[image_key] %}
        {% assign label = block.settings[label_key] %}
        
        <div class="beauty-carousel__slide-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
          <div class="beauty-carousel__media-container-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ label | escape }}"
                loading="lazy"
                class="beauty-carousel__image-{{ ai_gen_id }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="beauty-carousel__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if label != blank %}
            <div class="beauty-carousel__label-{{ ai_gen_id }}">{{ label }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div><div class="beauty-carousel__nav-{{ ai_gen_id }}">
      <button class="beauty-carousel__nav-button-{{ ai_gen_id }} prev" aria-label="Previous slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="beauty-carousel__nav-button-{{ ai_gen_id }} next" aria-label="Next slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    <div class="beauty-carousel__controls-{{ ai_gen_id }}">
      <button class="beauty-carousel__autoplay-button-{{ ai_gen_id }}" aria-label="Toggle autoplay">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="play-icon">
          <path d="M8 5V19L19 12L8 5Z" fill="currentColor"/>
        </svg>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="pause-icon" style="display: none;">
          <path d="M6 4H10V20H6V4Z" fill="currentColor"/>
          <path d="M14 4H18V20H14V4Z" fill="currentColor"/>
        </svg>
      </button>
    </div>
    <div class="beauty-carousel__dots-{{ ai_gen_id }}"></div>
  </beauty-device-carousel-{{ ai_gen_id }}>
</div>

<script>
  (function() {
    class BeautyDeviceCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.beauty-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.beauty-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.beauty-carousel__nav-button-{{ ai_gen_id }}.prev');
        this.nextButton = this.querySelector('.beauty-carousel__nav-button-{{ ai_gen_id }}.next');
        this.dotsContainer = this.querySelector('.beauty-carousel__dots-{{ ai_gen_id }}');
        this.autoplayButton = this.querySelector('.beauty-carousel__autoplay-button-{{ ai_gen_id }}');
        this.playIcon = this.autoplayButton?.querySelector('.play-icon');
        this.pauseIcon = this.autoplayButton?.querySelector('.pause-icon');
        this.currentIndex = 0;
        this.slidesPerView = window.innerWidth <= 749 ? 
          {{ block.settings.visible_slides_mobile }} : 
          {{ block.settings.visible_slides }};
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
        
        // Autoplay settings
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplayInterval = parseInt(this.dataset.interval) * 1000;
        this.autoplayTimer = null;
      }
      
      connectedCallback() {
        this.init();
        this.setupEventListeners();window.addEventListener('resize', this.handleResize.bind(this));
        
        // Start autoplay if enabled
        if (this.autoplay) {
          this.startAutoplay();
          this.updateAutoplayButton();
        }
      }
      
      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', this.handleResize.bind(this));
      }
      
      init() {
        // Create dots
        this.createDots();
        this.updateDots();
        
        // Set initial position
        this.updateSlidePosition();
      }
      
      createDots() {
        this.dotsContainer.innerHTML = '';
        const dotsCount = this.maxIndex + 1;
        for (let i = 0; i < dotsCount; i++) {
          const dot = document.createElement('div');
          dot.classList.add('beauty-carousel__dot-{{ ai_gen_id }}');
          dot.dataset.index = i;
          this.dotsContainer.appendChild(dot);dot.addEventListener('click', () => {
            this.goToSlide(parseInt(dot.dataset.index));
          });
        }
      }
      
      updateDots() {
        const dots = this.dotsContainer.querySelectorAll('.beauty-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
      
      setupEventListeners() {
        if (this.prevButton && this.nextButton) {
          this.prevButton.addEventListener('click', this.prev.bind(this));
          this.nextButton.addEventListener('click', this.next.bind(this));
        }
        
        if (this.autoplayButton) {
          this.autoplayButton.addEventListener('click', this.toggleAutoplay.bind(this));
        }// Add touch support
        let startX, endX;
        this.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          this.pauseOnInteraction();
        }, { passive: true });
        this.addEventListener('touchend', (e) => {
          endX = e.changedTouches[0].clientX;
          if (startX - endX > 50) {
            this.next();
          } else if (endX - startX > 50) {
            this.prev();
          }
          this.resumeAfterInteraction();
        }, { passive: true });
        
        // Pause autoplay on mouse interaction
        this.addEventListener('mouseenter', this.pauseOnInteraction.bind(this));
        this.addEventListener('mouseleave', this.resumeAfterInteraction.bind(this));
      }
      
      handleResize() {
        const newSlidesPerView = window.innerWidth <= 749 ? 
          {{ block.settings.visible_slides_mobile }} : 
          {{ block.settings.visible_slides }};
        if (newSlidesPerView !== this.slidesPerView) {
          this.slidesPerView = newSlidesPerView;
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          
          // Make sure current index is valid after resize
          if (this.currentIndex > this.maxIndex) {
            this.currentIndex = this.maxIndex;
          }
          
          this.createDots();
          this.updateDots();
          this.updateSlidePosition();
        }
      }
      
      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlidePosition();
          this.updateDots();
        } else if ({{ block.settings.loop }}) {
          // Loop to the end if loop is enabled
          this.currentIndex = this.maxIndex;
          this.updateSlidePosition();
          this.updateDots();
        }
      }
      
      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateSlidePosition();
          this.updateDots();
        } else if ({{ block.settings.loop }}) {
          // Loop to the beginning if loop is enabled
          this.currentIndex = 0;
          this.updateSlidePosition();
          this.updateDots();
        }
      }
      
      goToSlide(index) {
        if (index >= 0 && index <= this.maxIndex) {
          this.currentIndex = index;
          this.updateSlidePosition();
          this.updateDots();
        }
      }
      
      updateSlidePosition() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.gap }};
        const offset = this.currentIndex * (slideWidth + gap);
        this.track.style.transform = `translateX(-${offset}px)`;
      }
      
      startAutoplay() {
        if (this.autoplayTimer) this.stopAutoplay();
        this.autoplay = true;
        this.autoplayTimer = setInterval(() => {
          if (this.currentIndex < this.maxIndex) {
            this.next();
          } else {
            this.goToSlide(0);
          }
        }, this.autoplayInterval);
        this.updateAutoplayButton();
      }
      
      stopAutoplay() {
        this.autoplay = false;
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;}
        this.updateAutoplayButton();
      }
      
      toggleAutoplay() {
        if (this.autoplay) {
          this.stopAutoplay();
        } else {
          this.startAutoplay();
        }
      }
      
      updateAutoplayButton() {
        if (!this.playIcon || !this.pauseIcon) return;
        
        if (this.autoplay) {
          this.playIcon.style.display = 'none';
          this.pauseIcon.style.display = 'block';
        } else {
          this.playIcon.style.display = 'block';
          this.pauseIcon.style.display = 'none';
        }
      }
      
      pauseOnInteraction() {
        if (this.autoplay) {
          this.wasAutoPlaying = true;
          this.stopAutoplay();
        }
      }
      
      resumeAfterInteraction() {
        if (this.wasAutoPlaying && {{ block.settings.pause_on_hover }} === false) {
          this.startAutoplay();this.wasAutoPlaying = false;
        }
      }}
    
    customElements.define('beauty-device-carousel-{{ ai_gen_id }}', BeautyDeviceCarousel{{ ai_gen_id }});
  })();
</script>

