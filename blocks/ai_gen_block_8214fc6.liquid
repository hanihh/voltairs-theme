{% doc %}
  @prompt
    Create an Expandable Therapy Slider Banner (Image/Video + Dynamic Slides):
    Design a modern, responsive slider banner that showcases multiple therapy features of a wellness or beauty device. The section should include:
    
    ✅ Layout:
    A 2-column layout per slide:
    
    Left side: device in use photo or embedded video (optional play icon overlay if video)
    
    Right side: text box with:
    
    Title: “3 Proven Therapies, 1 Powerful Device” (bold, centered, split by a comma)
    
    3 stacked or horizontal therapy cards (icons + titles + short descriptions)
    
    Example:
    
    🔴 Red-Light Therapy – Rejuvenates the skin, stimulates collagen production, and improves overall appearance.
    
    💪 Sculpting Therapy – Breaks down fatty tissue, promotes better lymphatic flow.
    
    💨 Vacuum Therapy – Lifts, firms, and smooths skin.
    
    ✅ Dynamic Control:
    Provide a dropdown, slider, or stepper input allowing users to choose number of slides to display:
    
    Minimum: 3 slides
    
    Maximum: 6 slides
    
    Slides not selected are hidden by default
    
    Clicking arrows or swiping navigates the visible slides only
    
    ✅ Slide Content Options:
    Each slide may have unique media:
    
    Upload either an image or a video for each slide
    
    System should auto-detect and render the proper format
    
    ✅ Design Style:
    Background: soft blush pink (#FFEAEA or #FDEFF2)
    
    Font: modern (e.g. Poppins, Inter)
    
    Therapy icons: simple line or flat icons (centered and color-coded)
    
    Card layout with rounded corners, light shadows
    
    CTA Button optional below each slide (e.g., “Learn More” or “Shop Now”)
    
    Smooth transitions on slide switch
    
    ✅ Optional Features:
    Dot navigation or progress indicator
    
    Autoplay toggle
    
    “Add New Slide” and “Remove Slide” admin control, remove the slide ability , just keep it only 1 , remove arrows and hint poijnts, make the vertical layout also full width , i want abilite to upload icon/image or select emoji and not only stick to emoji, and i want to be able to  add up to 9 items not only 3 , with hide/show option. and control the colums count and boarder amd shadow and radius

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .therapy-banner-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .therapy-banner__container-{{ ai_gen_id }} {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .therapy-banner__content-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  @media screen and (min-width: 768px) {
    .therapy-banner__content-wrapper-{{ ai_gen_id }} {
      flex-direction: row;
    }
  }

  .therapy-banner__media-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.media_shadow_h_offset }}px {{ block.settings.media_shadow_v_offset }}px {{ block.settings.media_shadow_blur }}px {{ block.settings.media_shadow_spread }}px {{ block.settings.media_shadow_color }}{{ block.settings.media_shadow_opacity | divided_by: 100.0 }};
    border: {{ block.settings.media_border_width }}px solid {{ block.settings.media_border_color }};
  }

  .therapy-banner__media-{{ ai_gen_id }} img,
  .therapy-banner__media-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .therapy-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 300px;
  }

  .therapy-banner__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.5;
  }

  .therapy-banner__video-play-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
  }

  .therapy-banner__video-play-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .therapy-banner__content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 20px;
  }

  .therapy-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: bold;
    margin-bottom: 30px;
    text-align: center;
    color: {{ block.settings.title_color }};
  }

  .therapy-banner__title-{{ ai_gen_id }} span {
    display: block;
  }

  .therapy-banner__therapies-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: 20px;
    margin-bottom: 30px;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    .therapy-banner__therapies-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .therapy-banner__therapy-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: 20px;
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: {{ block.settings.card_shadow_h_offset }}px {{ block.settings.card_shadow_v_offset }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_spread }}px {{ block.settings.card_shadow_color }}{{ block.settings.card_shadow_opacity | divided_by: 100.0 }};
    transition: transform 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .therapy-banner__therapy-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .therapy-banner__therapy-icon-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    margin: 0 auto 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 24px;
  }

  .therapy-banner__therapy-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .therapy-banner__therapy-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.therapy_title_size }}px;
    font-weight: 600;
    margin-bottom: 10px;
    text-align: center;
    color: {{ block.settings.therapy_title_color }};
  }

  .therapy-banner__therapy-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.therapy_text_size }}px;
    color: {{ block.settings.therapy_text_color }};
    text-align: center;
  }

  .therapy-banner__cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: auto;
  }

  .therapy-banner__cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .therapy-banner__cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
  }
{% endstyle %}

<therapy-banner-{{ ai_gen_id }} class="therapy-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="therapy-banner__container-{{ ai_gen_id }}">
    <div class="therapy-banner__content-wrapper-{{ ai_gen_id }}">
      <div class="therapy-banner__media-{{ ai_gen_id }}">
        {% if block.settings.media %}
          {% if block.settings.media_type == 'video' %}
            <video 
              src="{{ block.settings.media | file_url }}"
              poster="{{ block.settings.media | image_url }}"
              controls
              playsinline
              muted
              loop
            ></video>
            <div class="therapy-banner__video-play-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5V19L19 12L8 5Z" fill="currentColor"/>
              </svg>
            </div>
          {% else %}
            <img 
              src="{{ block.settings.media | image_url: width: 800 }}"
              alt="{{ block.settings.media.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.media.width }}"
              height="{{ block.settings.media.height }}"
            >
          {% endif %}
        {% else %}
          <div class="therapy-banner__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="therapy-banner__content-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="therapy-banner__title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h2>
        {% endif %}

        <div class="therapy-banner__therapies-{{ ai_gen_id }}">
          {% for i in (1..9) %}
            {% assign therapy_enabled_key = 'therapy' | append: i | append: '_enabled' %}
            {% assign therapy_icon_type_key = 'therapy' | append: i | append: '_icon_type' %}
            {% assign therapy_icon_key = 'therapy' | append: i | append: '_icon' %}
            {% assign therapy_icon_image_key = 'therapy' | append: i | append: '_icon_image' %}
            {% assign therapy_title_key = 'therapy' | append: i | append: '_title' %}
            {% assign therapy_description_key = 'therapy' | append: i | append: '_description' %}
            {% assign therapy_color_key = 'therapy' | append: i | append: '_color' %}

            {% if block.settings[therapy_enabled_key] %}
              <div class="therapy-banner__therapy-{{ ai_gen_id }}">
                <div class="therapy-banner__therapy-icon-{{ ai_gen_id }}" style="background-color: {{ block.settings[therapy_color_key] }}20;">
                  {% if block.settings[therapy_icon_type_key] == 'emoji' %}
                    <span style="color: {{ block.settings[therapy_color_key] }}">{{ block.settings[therapy_icon_key] }}</span>
                  {% else %}
                    {% if block.settings[therapy_icon_image_key] %}
                      <img 
                        src="{{ block.settings[therapy_icon_image_key] | image_url: width: 100 }}"
                        alt="{{ block.settings[therapy_icon_image_key].alt | escape }}"
                        loading="lazy"
                        width="50"
                        height="50"
                      >
                    {% endif %}
                  {% endif %}
                </div>
                <h3 class="therapy-banner__therapy-title-{{ ai_gen_id }}">{{ block.settings[therapy_title_key] }}</h3>
                <div class="therapy-banner__therapy-description-{{ ai_gen_id }}">{{ block.settings[therapy_description_key] }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <div class="therapy-banner__cta-{{ ai_gen_id }}">
            <a href="{{ block.settings.button_link }}" class="therapy-banner__cta-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</therapy-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class TherapyBanner extends HTMLElement {
      constructor() {
        super();
        this.videoPlayButton = this.querySelector('.therapy-banner__video-play-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupVideoPlayButton();
      }
      
      setupVideoPlayButton() {
        if (!this.videoPlayButton) return;
        
        const video = this.videoPlayButton.previousElementSibling;
        
        this.videoPlayButton.addEventListener('click', () => {
          if (video.paused) {
            video.play();
            this.videoPlayButton.style.display = 'none';
          } else {
            video.pause();
            this.videoPlayButton.style.display = 'flex';
          }
        });
        
        video.addEventListener('play', () => {
          this.videoPlayButton.style.display = 'none';
        });
        
        video.addEventListener('pause', () => {
          this.videoPlayButton.style.display = 'flex';
        });
        
        video.addEventListener('ended', () => {
          this.videoPlayButton.style.display = 'flex';
        });
      }
    }
    
    customElements.define('therapy-banner-{{ ai_gen_id }}', TherapyBanner);
  })();
</script>

