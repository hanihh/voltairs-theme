              "blocks": {
                "text_9gAcB8": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Inspired by hospital-grade DVT sleeves and lymphatic massage therapy, this device combines compression + heat to mimic real muscle recovery protocols but in a portable, wearable form.</p>",
